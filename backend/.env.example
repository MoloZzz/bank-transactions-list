# Single connection string for Postgres (Nest runtime + TypeORM CLI migrations)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/transactions
DB_LOGGING=false

# --- Monobank (live source). Token from https://api.monobank.ua/ ---
# MONOBANK_TOKEN=
# Backfill start; default 2017-01-01 (full history). ISO date.
# MONO_SINCE=2017-01-01

# --- Google Sheets export (optional; without it sync still writes to DB) ---
# Inline service-account JSON or a path to the .json file:
# GOOGLE_SERVICE_ACCOUNT_JSON=
# SHEETS_SPREADSHEET_ID=
# SHEETS_TAB=Sheet1
